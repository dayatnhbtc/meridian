{
  "name": "dlmm-agent",
  "version": "1.0.0",
  "type": "module",
  "description": "Autonomous DLMM LP agent for Meteora on Solana",
  "main": "index.js",
  "bin": {
    "meridian": "cli.js"
  },
  "scripts": {
    "setup": "node setup.js",
    "env:encrypt": "node scripts/envrypt.js encrypt",
    "start": "node index.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart meridian --update-env",
    "pm2:logs": "pm2 logs meridian --lines 100",
    "dev": "DRY_RUN=true node index.js",
    "test": "npm run test:syntax && npm run test:report-format && npm run test:telegram-commands && npm run test:paper && npm run test:paper-autoclose && npm run test:paper-dashboard && npm run test:evil-panda && npm run test:live-safety && npm run test:post-loss-guards",
    "test:syntax": "find . -path ./node_modules -prune -o -name '*.js' -exec node --check {} \\;",
    "test:report-format": "node test/test-report-format.js",
    "test:telegram-commands": "node test/test-telegram-commands.js",
    "test:paper": "node test/test-paper-maxpositions.js",
    "test:paper-autoclose": "node test/test-paper-autoclose.js",
    "test:paper-dashboard": "node test/test-paper-dashboard.js",
    "test:evil-panda": "node test/test-evil-panda.js",
    "test:live-safety": "node test/test-live-safety.js",
    "test:post-loss-guards": "node test/test-post-loss-guards.js",
    "dashboard:paper": "node paper-dashboard.js",
    "dashboard:paper:lan": "PAPER_DASHBOARD_HOST=0.0.0.0 node paper-dashboard.js",
    "dashboard:paper:once": "node paper-dashboard.js --once",
    "test:screen": "node test/test-screening.js",
    "test:agent": "DRY_RUN=true node test/test-agent.js",
    "postinstall": "node scripts/patch-anchor.js"
  },
  "knip": {
    "ignore": [
      "discord-listener/**"
    ]
  },
  "dependencies": {
    "@meteora-ag/dlmm": "1.9.4",
    "@solana/web3.js": "^1.95.0",
    "bn.js": "^5.2.1",
    "bs58": "^5.0.0",
    "dotenv": "^17.3.1",
    "jsonrepair": "^3.13.3",
    "node-cron": "^3.0.3",
    "openai": "^4.73.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
